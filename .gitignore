# ---------------------------------------------------------------------------
# Dependencies & build output
# ---------------------------------------------------------------------------
node_modules/
dist/
build/
*.tsbuildinfo

# ---------------------------------------------------------------------------
# Environment & secrets
# Never commit real credentials. Only the .env.example template is tracked.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
*.local

# Private keys, certificates & keystores
*.pem
*.key
*.crt
*.cert
*.cer
*.der
*.p12
*.pfx
*.p7b
*.jks
*.keystore
*.asc
*.gpg

# SSH / signing keys
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*

# Credential & token files
secrets/
credentials.json
*credentials*.json
service-account*.json
gha-creds-*.json
.npmrc
.pgpass
.netrc
.aws/
.gcloud/

# ---------------------------------------------------------------------------
# Logs & runtime
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid

# ---------------------------------------------------------------------------
# Test & coverage output
# ---------------------------------------------------------------------------
coverage/
.nyc_output/

# ---------------------------------------------------------------------------
# OS & editor
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp

# ---------------------------------------------------------------------------
# Markdown
# Ignore all Markdown (notes, docs, scratch — CLAUDE.md, architecture.md, etc.)
# except the public README and the .claude/ slash-command files.
# ---------------------------------------------------------------------------
*.md
!README.md
!.claude/**/*.md
